pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                script {
                    def run
                    def buildCmd
                    def runCmd
                    def artifact

                    if (isUnix()) {
                        run = this.&sh
                        buildCmd = 'g++ -std=c++20 HelloWorld/HelloWorld.cpp -o HelloWorldApp'
                        runCmd = './HelloWorldApp'
                        artifact = 'HelloWorldApp'
                    } else {
                        run = this.&bat
                        buildCmd = 'g++ -std=c++20 HelloWorld\\HelloWorld.cpp -o HelloWorldApp.exe'
                        runCmd = 'HelloWorldApp.exe'
                        artifact = 'HelloWorldApp.exe'
                    }

                    run 'g++ --version'
                    run buildCmd
                    run runCmd

                    archiveArtifacts artifacts: artifact, fingerprint: true
                }
            }
        }
    }
}
